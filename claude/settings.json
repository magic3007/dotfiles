{
  "env": {
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "64000",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_MODEL": "claude-4-5-opus",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS":"1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(command:*)",
      "Bash(source:*)",
      "Bash(curl:*)",
      "Bash(bash:*)",
      "Bash(export NVM_DIR=\"$HOME/.nvm\":*)",
      "Bash([:*)",
      "Bash(. \"$NVM_DIR/nvm.sh\":*)",
      "Bash(nvm install:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(git commit:*)",
      "Bash(codex:*)",
      "Bash(echo:*)",
      "Bash(export PATH:*)",
      "Bash(~/.nvm/versions/node/v24.13.0/bin/codex:*)",
      "Bash(./install:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(chmod:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-expert-update.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true
  },
  "language": "Chinese",
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
