{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_MODEL": "claude-4-6-opus",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(command:*)",
      "Bash(source:*)",
      "Bash(curl:*)",
      "Bash(bash:*)",
      "Bash(export NVM_DIR=\"$HOME/.nvm\":*)",
      "Bash([:*)",
      "Bash(. \"$NVM_DIR/nvm.sh\":*)",
      "Bash(nvm install:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(git commit:*)",
      "Bash(codex:*)",
      "Bash(echo:*)",
      "Bash(export PATH:*)",
      "Bash(~/.nvm/versions/node/v24.13.0/bin/codex:*)",
      "Bash(./install:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(chmod:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/check_dangerous_ops.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-expert-update.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-end-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {},
  "extraKnownMarketplaces": {
    "minimax-matrix-plugins": {
      "source": {
        "source": "git",
        "url": "https://gitlab.xaminim.com/common/plugins.git"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/skills.git"
      }
    }
  },
  "language": "Chinese",
  "skipWebFetchPreflight": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
