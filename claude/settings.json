{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_MODEL": "claude-4-6-opus",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ANTHROPIC_BASE_URL": "https://platform-api.xaminim.com",
    "ANTHROPIC_CUSTOM_HEADERS": "X-Sub-Module: claude-code-internal",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5-20251001",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6-thinking-max",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_MODEL": "claude-opus-4-6-thinking-max",
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "ANTHROPIC_AUTH_TOKEN": "sk-YrQNlVVoo3TOIWxce0pu96VFSKiSL5MZD0vBgu59uXMDBKNK",
    "DISABLE_TELEMETRY": "1"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(command:*)",
      "Bash(source:*)",
      "Bash(curl:*)",
      "Bash(bash:*)",
      "Bash(export NVM_DIR=\"$HOME/.nvm\":*)",
      "Bash([:*)",
      "Bash(. \"$NVM_DIR/nvm.sh\":*)",
      "Bash(nvm install:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(git commit:*)",
      "Bash(codex:*)",
      "Bash(echo:*)",
      "Bash(export PATH:*)",
      "Bash(~/.nvm/versions/node/v24.13.0/bin/codex:*)",
      "Bash(./install:*)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(chmod:*)"
    ],
    "deny": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/scripts/check_dangerous_ops.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/check-expert-update.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claudeception-activator.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-end-reminder.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-end-reminder.sh"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-end-reminder.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "feishu@minimax-plugins": true
  },
  "extraKnownMarketplaces": {
    "minimax-matrix-plugins": {
      "source": {
        "source": "git",
        "url": "https://gitlab.xaminim.com/common/plugins.git"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "git",
        "url": "https://github.com/anthropics/skills.git"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    }
  },
  "language": "Chinese",
  "skipWebFetchPreflight": true,
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
